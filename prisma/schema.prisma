generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  users     User[]
}

model Sede {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  users     User[]
}

model UnidadNegocio {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  users     User[]
}

model Cargo {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  users     User[]
  questions QuestionCargo[]
  flowApprovals       QuestionFlowConfig[]  @relation("FlowApproval")
  flowTriggers        QuestionFlowTrigger[] @relation("FlowDelegation")
  answerApprovals     AnswerApproval[]      @relation("ApprovalCargo")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String?
  roleId        Int       @default(2)
  sedeId        Int?
  unidadId     Int?
  cargoId       Int?
  role          Role      @relation(fields: [roleId], references: [id])
  sede          Sede?     @relation(fields: [sedeId], references: [id])
  unidadNegocio UnidadNegocio? @relation(fields: [unidadId], references: [id])
  cargo         Cargo?    @relation(fields: [cargoId], references: [id])
  createdAt     DateTime  @default(now())
  evaluations   Evaluation[]
  campaigns     CampaignUser[]
  programs      UserProgram[]
  answersReviewed Answer[]  @relation("AnswerReviewer")
  delegationsCompleted AnswerDelegation[] @relation("DelegationCompleter")
  approvalsDecided     AnswerApproval[]   @relation("ApprovalDecider")
  uploadedFiles        AnswerFile[]        @relation("FileUploader")
}

model Campaign {
  id          Int        @id @default(autoincrement())
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  evaluations Evaluation[]
  assignedUsers CampaignUser[]
}

model CampaignUser {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  userId      Int
  assignedAt  DateTime @default(now())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
}

model Question {
  id                Int       @id @default(autoincrement())
  text              String
  description       String?   // Descripción de la pregunta
  points            Int       @default(3) // Puntaje personalizable por pregunta
  frequencyType     String    @default("UNICA") // UNICA, DIARIA, SEMANAL, MENSUAL, ANUAL, DIA_ESPECIFICO
  frequencyDay      Int?      // Día del mes (1-31), día de la semana (1-7), o día específico según frequencyType
  frequencyInterval Int?      // Cada cuántos períodos (ej: cada 2 semanas)
  isActive          Boolean   @default(true)
  order             Int       @default(0)
  createdAt         DateTime  @default(now())
  // targetType: EXCELENCIA = solo autoevaluación, MIS_PROGRAMAS = solo programas, AMBOS = ambos
  targetType       String    @default("AMBOS")
  // Para integración con Excel importado
  type          String    @default("NORMAL")  // NORMAL | EXCEL_DATA
  excelConfigId Int?                       // FK a ProgramFileConfig
  hidden        Boolean  @default(false)    // true = no aparece en lista de preguntas
  configs           QuestionConfig[]
  answers           Answer[]
  cargos            QuestionCargo[]
  submissions       QuestionSubmission[]
  options           QuestionOption[]
  selectors         QuestionSelector[]
  programs          QuestionProgram[]
  flowConfig        QuestionFlowConfig?
}

model QuestionCargo {
  id        Int      @id @default(autoincrement())
  questionId Int
  cargoId   Int
  question  Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  cargo     Cargo    @relation(fields: [cargoId], references: [id])

  @@unique([questionId, cargoId])
}

model QuestionOption {
  id          Int      @id @default(autoincrement())
  questionId  Int
  label       String   // A, B, C, D, etc.
  text        String   // Texto de la opción
  score       Int      // Puntaje asignado a esta opción
  isDefault   Boolean  @default(false) // Indica si es la opción por defecto
  semanticKey String?
  isLocked    Boolean  @default(false)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers     Answer[]
  flowTriggers QuestionFlowTrigger[]

  @@unique([questionId, label])
  @@unique([questionId, semanticKey])
}

model QuestionSelector {
  id              Int      @id @default(autoincrement())
  questionId       Int
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectorKey     String   // identificador único dentro de la pregunta ("requires_plan", "evidencia_presencial")
  label           String   // texto mostrado al usuario
  selectorType    String   // YES_NO | YES_NO_NA | CUSTOM | COMPLIANCE | SCALE_1_5
  renderAs        String   // RADIO | BUTTONS | SELECT | CHECKBOX
  allowsMultiple  Boolean  @default(false)
  required       Boolean  @default(true)
  order          Int      @default(0)
  options        QuestionSelectorOption[]
  flowTriggers  QuestionFlowTrigger[]

  @@unique([questionId, selectorKey])
}

model QuestionSelectorOption {
  id            Int               @id @default(autoincrement())
  selectorId    Int
  selector      QuestionSelector  @relation(fields: [selectorId], references: [id], onDelete: Cascade)
  label         String            // "A", "B", "Sí"
  text          String
  semanticKey   String?          // YES, NO, NA, COMPLIANT...
  order         Int              @default(0)
}

model EvaluationAnswerSelector {
  id                Int      @id @default(autoincrement())
  answerId          Int
  answer            Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  selectorId        Int
  selectedOptionIds  Int[]
  createdAt        DateTime @default(now())

  @@unique([answerId, selectorId])
}

model QuestionConfig {
  id          Int      @id @default(autoincrement())
  questionId  Int
  fileType    String   // IMAGEN, PDF, PPT, EXCEL
  maxFiles    Int      @default(1) // cantidad máxima de archivos de este tipo
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, fileType])
}

model Evaluation {
  id          Int       @id @default(autoincrement())
  userId      Int
  campaignId  Int
  source      String    @default("EXCELENCIA")  // EXCELENCIA, MIS_PROGRAMAS
  programId   Int?      // Programa relacionado (para MIS_PROGRAMAS)
  totalScore  Int       @default(0)
  maxScore    Int       @default(0) // puntaje máximo posible
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  program     Program?  @relation(fields: [programId], references: [id])
  answers     Answer[]
  
  // Resultado Final del Admin
  adminFinalScore   Int?
  adminFinalComment String?
  adminPublishedAt  DateTime?

  @@unique([userId, campaignId, source, programId])
}

model Answer {
  id             Int        @id @default(autoincrement())
  evaluationId   Int
  questionId     Int
  optionId       Int?       // Opción seleccionada por el usuario
  optionIds      Int[]
  detailText     String?
  awardedScore   Int        @default(0)
  hasEvidence    Boolean    @default(false)
  status         String     @default("ANSWERED") // DRAFT | ANSWERED | PENDING_DELEGATION | PENDING_APPROVAL | COMPLETED | EXPIRED
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  // Campos de período (según frecuencia de pregunta)
  periodStart    DateTime?  // Inicio del período (ej: lunes de la semana)
  periodEnd      DateTime?  // Fin del período (ej: domingo)
  // Campos de revisión por admin
  adminScore     Int?       // Puntaje final dado por admin (por pregunta)
  adminComment   String?    // Comentario del admin
  adminReviewedAt DateTime? // Cuándo fue revisado
  reviewedById   Int?       // FK al admin que revisó (User.id)
  // Relaciones
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question       Question   @relation(fields: [questionId], references: [id])
  option         QuestionOption? @relation(fields: [optionId], references: [id])
  files          AnswerFile[]
  selectorResponses EvaluationAnswerSelector[]
  reviewedBy     User?      @relation("AnswerReviewer", fields: [reviewedById], references: [id])
  delegation    AnswerDelegation?
  approval      AnswerApproval?

  @@unique([evaluationId, questionId, periodStart])
}

model AnswerFile {
  id          Int      @id @default(autoincrement())
  answerId    Int
  fileType    String   // IMAGEN, PDF, PPT, EXCEL
  fileName    String
  fileUrl     String
  phase      String   @default("RESPONDER")   // RESPONDER | DELEGATE
  uploadedByUserId  Int?
  createdAt   DateTime @default(now())
  answer      Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  uploadedBy  User?    @relation("FileUploader", fields: [uploadedByUserId], references: [id])
}

// Registra cuándo se respondió cada pregunta (para control de frecuencia)
model QuestionSubmission {
  id           Int      @id @default(autoincrement())
  questionId   Int
  userId       Int
  campaignId   Int
  submissionDate DateTime // Fecha en que se respondió esta instancia de la pregunta
  periodStart  DateTime // Inicio del período (ej: lunes para semanal, 1ro del mes para mensual)
  periodEnd    DateTime // Fin del período
  createdAt    DateTime @default(now())
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId, campaignId, periodStart])
}

// ==================== PROGRAMAS DE EXCELENCIA ====================
model Program {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  users       UserProgram[]
  questions   QuestionProgram[]
  evaluations Evaluation[]
  fileConfig  ProgramFileConfig?
}

model UserProgram {
  id        Int      @id @default(autoincrement())
  userId    Int
  programId Int
  assignedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
}

model QuestionProgram {
  id         Int      @id @default(autoincrement())
  questionId Int
  programId  Int
  assignedAt DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([questionId, programId])
}

// ==================== EXCEL CONFIG POR PROGRAMA ====================
model ProgramFileConfig {
  id            Int      @id @default(autoincrement())
  programId     Int      @unique
  fileName      String
  frequencyType String   @default("MENSUAL")
  executionDay  Int?
  structureMap  Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  program       Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  records       MonthlyRecord[]
}

model MonthlyRecord {
  id          Int       @id @default(autoincrement())
  configId    Int
  period      String
  data        Json
  status      String    @default("PENDIENTE")
  source      String    @default("MANUAL")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  config      ProgramFileConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, period])
}

// ==================== FLUJO DE PREGUNTAS: APROBACIÓN + DELEGACIÓN ====================

// Configuración de flujo por pregunta (singleton)
model QuestionFlowConfig {
  id                     Int       @id @default(autoincrement())
  questionId             Int       @unique
  isActive               Boolean   @default(true)

  // --- APROBACIÓN ---
  requiresApproval       Boolean   @default(false)
  approvalCargoId        Int?

  // --- DELEGACIÓN (parámetros globales; los triggers viven en tabla hija) ---
  requiresDelegation     Boolean   @default(false)
  deadlineOffsetDays     Int       @default(2)
  deadlineBusinessDays   Boolean   @default(false)

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  question               Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  approvalCargo          Cargo?                @relation("FlowApproval", fields: [approvalCargoId], references: [id], onDelete: SetNull)
  triggers               QuestionFlowTrigger[]

  @@index([isActive])
}

// Triggers de delegación: N por config
model QuestionFlowTrigger {
  id                     Int       @id @default(autoincrement())
  flowConfigId           Int
  delegateCargoId        Int

  triggerMode            String    @default("OPTION_SEMANTIC") // OPTION_SEMANTIC | OPTION_ID | SCORE_LTE | SCORE_GTE | ALWAYS | SELECTOR_OPTION | SELECTOR_SEMANTIC
  triggerSemanticKey     String?
  triggerOptionId        Int?                            // usado si mode = OPTION_ID
  triggerScore           Int?                            // usado si mode = SCORE_LTE / SCORE_GTE
  // Nuevos campos para selectores
  triggerSelectorId        Int?                            // usado si mode = SELECTOR_OPTION | SELECTOR_SEMANTIC
  triggerSelectorOptionId Int?                         // usado si mode = SELECTOR_OPTION
  triggerSelectorSemanticKey String?                   // usado si mode = SELECTOR_SEMANTIC

  secondFileType         String    @default("EXCEL")     // IMAGEN / PDF / PPT / EXCEL
  secondFileMaxFiles     Int       @default(1)
  secondFileLabel        String    @default("Plan de Acción")

  flowConfig             QuestionFlowConfig @relation(fields: [flowConfigId], references: [id], onDelete: Cascade)
  triggerOption          QuestionOption?    @relation(fields: [triggerOptionId], references: [id], onDelete: Cascade)
  triggerSelector      QuestionSelector? @relation(fields: [triggerSelectorId], references: [id], onDelete: Cascade)
  delegateCargo          Cargo              @relation("FlowDelegation", fields: [delegateCargoId], references: [id])
  delegations            AnswerDelegation[]

  @@unique([flowConfigId, triggerOptionId])
  @@unique([flowConfigId, triggerSemanticKey])
  @@index([delegateCargoId])
}

// Instancia de delegación (una por Answer gatilladora)
model AnswerDelegation {
  id                Int       @id @default(autoincrement())
  answerId          Int       @unique
  triggerId         Int
  deadlineAt        DateTime
  status            String    @default("PENDIENTE")     // PENDIENTE | COMPLETADO | VENCIDO | CANCELADA
  completedAt       DateTime?
  completedByUserId Int?
  cancelledAt       DateTime?
  isLate            Boolean   @default(false)
  createdAt         DateTime  @default(now())

  answer            Answer              @relation(fields: [answerId], references: [id], onDelete: Cascade)
  trigger           QuestionFlowTrigger @relation(fields: [triggerId], references: [id])
  completedBy       User?               @relation("DelegationCompleter", fields: [completedByUserId], references: [id])

  @@index([status, deadlineAt])
}

// Instancia de aprobación (una por Answer que requiere aprobación)
model AnswerApproval {
  id              Int       @id @default(autoincrement())
  answerId        Int       @unique
  approverCargoId Int
  status          String    @default("PENDIENTE")       // PENDIENTE | APROBADA | RECHAZADA
  decidedAt       DateTime?
  decidedByUserId Int?
  comment         String?
  createdAt       DateTime  @default(now())

  answer          Answer    @relation(fields: [answerId], references: [id], onDelete: Cascade)
  approverCargo   Cargo     @relation("ApprovalCargo", fields: [approverCargoId], references: [id])
  decidedBy       User?     @relation("ApprovalDecider", fields: [decidedByUserId], references: [id])

  @@index([status, approverCargoId])
}